{
  "name": "dev/php-playground",
  "type": "project",
  "require": {
    "php": ">=8.4",
    "ext-pdo": "*",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "pestphp/pest": "^3.0",
    "symfony/var-dumper": "^7.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "pest",
    "dev": "php -S localhost:8000 -t public"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    },
    "process-timeout": 0
  }
}
